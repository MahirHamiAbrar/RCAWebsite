# Frontend uses this base URL for auth API calls.
# For local development with Next API routes, keep it empty or use http://localhost:3000
NEXT_PUBLIC_BACKEND_URL=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# Required for signing auth cookies (JWT)
AUTH_JWT_SECRET=change-this-to-a-very-long-random-secret

# Optional: override where JSON auth users are stored
# AUTH_DATA_FILE=./data/auth-users.json
